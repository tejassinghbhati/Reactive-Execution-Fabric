# Environment Configuration — Reactive Execution Fabric
# Copy this file to .env and fill in your values

# ── Anthropic (for agent calls) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ── Notification Platform ─────────────────────────────────────────────────────
# Which platform to send proactive messages to: discord | telegram | console
NOTIFY_PLATFORM=console

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_NOTIFY_CHANNEL_ID=your_default_channel_id_here

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_NOTIFY_CHAT_ID=your_default_chat_id_here

# ── GitHub Probe (optional) ───────────────────────────────────────────────────
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_WATCH_REPO=owner/repo-name

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Path to the SQLite job store file (relative to project root)
JOB_DB_PATH=./data/ref.db

# Max iterations for agent calls
AGENT_MAX_ITERATIONS=5
